{
  "name": "pi-security",
  "version": "1.0.0",
  "description": "In-process tool guard and subagent posture hardening for Pi coding agent. Enforces filesystem allow/deny lists and domain allowlists on read, write, edit, fetch_content, web_search, and get_search_content — with interactive ask-tier prompts to grant access without leaving pi.",
  "type": "module",
  "author": "Hannes",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "security",
    "sandbox",
    "guard",
    "policy"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hannesro/pi-security-workspace.git"
  },
  "bugs": {
    "url": "https://github.com/hannesro/pi-security-workspace/issues"
  },
  "homepage": "https://github.com/hannesro/pi-security-workspace#readme",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.26"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "pi": {
    "extensions": [
      "./security-guard.ts",
      "./sandbox/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "image": "https://raw.githubusercontent.com/hannesro/pi-security-workspace/main/banner.png"
  },
  "files": [
    "security-guard.ts",
    "sandbox/",
    "skills/",
    "sandbox.example.json",
    "banner.png",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ]
}
